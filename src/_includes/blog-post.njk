---
layout: base
renderPageHeader: false
---

{% set canonical = (site.url + page.url) if site and site.url else page.url %}
{% set postLocale = locale or site.locale or 'en' %}
{% set isPolishPost = postLocale == 'pl' %}
{% set organizationId = (site.url + '#organization') if site and site.url else '#organization' %}
{% set postImageUrl = (site.url + image) if site and site.url and image else image %}

<section class="section">
  <div class="container">
    <header class="post-header">
      <p class="post-meta">
        <a class="post-meta-link" href="{% if isPolishPost %}/pl/blog/{% else %}/blog/{% endif %}">Blog</a>
        {% if date %}
          <span aria-hidden="true">·</span>
          <time datetime="{{ date.toISOString() }}">{{ date | readableDate(postLocale) }}</time>
        {% endif %}
      </p>
      <h1 class="post-title">{{ title | escape }}</h1>
      {% if description %}
        <p class="post-lead">{{ description | escape }}</p>
      {% endif %}

      {% if image %}
        <figure class="post-figure">
          <img
            src="{{ image }}"
            alt="{{ imageAlt | default('') | escape }}"
            loading="eager"
            decoding="async"
            {% if imageWidth %}width="{{ imageWidth }}"{% endif %}
            {% if imageHeight %}height="{{ imageHeight }}"{% endif %}
          />
        </figure>
      {% endif %}
    </header>

    <article class="prose">
      {{ content | safe }}
    </article>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | json | safe }},
  {% if description %}"description": {{ description | json | safe }},{% endif %}
  {% if date %}"datePublished": {{ date.toISOString() | json | safe }},{% endif %}
  "inLanguage": {{ postLocale | json | safe }},
  {% if postImageUrl %}"image": {{ postImageUrl | json | safe }},{% endif %}
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ canonical | json | safe }}
  },
  "author": {
    "@type": "Organization",
    "@id": {{ organizationId | json | safe }},
    "name": {{ site.author.name | json | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "@id": {{ organizationId | json | safe }},
    "name": {{ site.name | json | safe }}
  }
}
</script>
