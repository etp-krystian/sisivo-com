---
layout: base
renderPageHeader: false
---

{% set canonical = (site.url + page.url) if site and site.url else page.url %}
{% set postLocale = locale or site.locale or 'en' %}
{% set isPolishPost = postLocale == 'pl' %}
{% set organizationId = (site.url + '#organization') if site and site.url else '#organization' %}
{% set postImageUrl = (site.url + image) if site and site.url and image else image %}
{% set blogIndexUrl = '/pl/blog/' if isPolishPost else '/en/blog/' %}
{% set consultingUrl = '/pl/konsulting-ai/' if isPolishPost else '/services/ai-consulting-strategy/' %}
{% set roadmapUrl = '/pl/roadmapa-ai/' if isPolishPost else '/services/ai-roadmap-development/' %}
{% set postCtaTitle = 'Potrzebujesz pomocy w stworzeniu roadmapy AI?' if isPolishPost else 'Need help building your AI roadmap?' %}
{% set postCtaBody = 'Pomożemy wybrać pierwszy use case, uporządkować priorytety i zaplanować wdrożenie AI z realnym efektem biznesowym.' if isPolishPost else 'We help teams choose the right first use case, align priorities, and turn AI ideas into a practical implementation roadmap.' %}
{% set roadmapButton = 'Otrzymaj roadmapę AI' if isPolishPost else 'Get AI Roadmap' %}
{% set strategyButton = 'Umów konsultację' if isPolishPost else 'Book Strategy Call' %}
{% set resourcesTitle = 'Powiązane kolejne kroki' if isPolishPost else 'Related next steps' %}
{% set consultingLinkLabel = 'Zobacz konsulting AI' if isPolishPost else 'Explore AI consulting services' %}
{% set roadmapLinkLabel = 'Zobacz stronę o roadmapie AI' if isPolishPost else 'Explore AI roadmap consulting' %}
{% set faqTitle = 'FAQ' %}

<section class="section">
  <div class="container">
    <header class="post-header">
      <p class="post-meta">
        <a class="post-meta-link" href="{{ blogIndexUrl }}">Blog</a>
        {% if date %}
          <span aria-hidden="true">·</span>
          <time datetime="{{ date.toISOString() }}">{{ date | readableDate(postLocale) }}</time>
        {% endif %}
      </p>
      <h1 class="post-title">{{ title | escape }}</h1>
      {% if description %}
        <p class="post-lead">{{ description | escape }}</p>
      {% endif %}

      {% if image %}
        <figure class="post-figure">
          <img
            src="{{ image }}"
            alt="{{ imageAlt | default('') | escape }}"
            loading="eager"
            decoding="async"
            {% if imageWidth %}width="{{ imageWidth }}"{% endif %}
            {% if imageHeight %}height="{{ imageHeight }}"{% endif %}
          />
        </figure>
      {% endif %}
    </header>

    <article class="prose">
      {{ content | safe }}
    </article>

    <section class="service-page-cta" aria-label="Blog post call to action">
      <h2>{{ postCtaTitle }}</h2>
      <p>{{ postCtaBody }}</p>
      <div class="home-cta">
        <a class="btn btn-primary" href="{{ roadmapUrl }}">{% ms "rocket_launch" %}<span>{{ roadmapButton }}</span></a>
        <a class="btn btn-ghost" href="https://calendar.app.google/R21jua9szDGa7T7c9">{% ms "calendar_month" %}<span>{{ strategyButton }}</span></a>
      </div>
    </section>

    <section class="prose">
      <h2>{{ resourcesTitle }}</h2>
      <ul>
        <li><a href="{{ consultingUrl }}">{{ consultingLinkLabel }}</a></li>
        <li><a href="{{ roadmapUrl }}">{{ roadmapLinkLabel }}</a></li>
      </ul>
    </section>

    {% if faqSchema and faqSchema.length %}
      <section class="prose">
        <h2>{{ faqTitle }}</h2>
        {% for item in faqSchema %}
          <h3>{{ item.question }}</h3>
          <p>{{ item.answer }}</p>
        {% endfor %}
      </section>
    {% endif %}
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | json | safe }},
  {% if description %}"description": {{ description | json | safe }},{% endif %}
  {% if date %}"datePublished": {{ date.toISOString() | json | safe }},{% endif %}
  "inLanguage": {{ postLocale | json | safe }},
  {% if postImageUrl %}"image": {{ postImageUrl | json | safe }},{% endif %}
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ canonical | json | safe }}
  },
  "author": {
    "@type": "Organization",
    "@id": {{ organizationId | json | safe }},
    "name": {{ site.author.name | json | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "@id": {{ organizationId | json | safe }},
    "name": {{ site.name | json | safe }}
  }
}
</script>
