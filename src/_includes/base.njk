<!doctype html>
{% set isHome = page.url == "/" %}
{% set isServicesIndex = page.url == "/services/" %}
{% set isServices = page.url and page.url.indexOf("/services/") == 0 %}
{% set isBlog = page.url and page.url.indexOf("/blog/") == 0 %}
{% set isBlogIndex = page.url == "/blog/" %}
{% set isLegal = page.url == "/privacy-policy/" or page.url == "/cookie-policy/" %}
<html lang="{{ site.locale or 'en' }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-NGX225S4");
    </script>
    <!-- End Google Tag Manager -->
    {% set metaTitle = title or "Easy Tech Partners" %}
    {% set metaDescription = description or "Easy Tech Partners — autonomous AI agents that plan, execute, and improve growth work end‑to‑end." %}
    <title>{{ metaTitle | escape }}</title>
    <meta name="description" content="{{ metaDescription | escape }}" />
    {% if site and site.url and site.url.length %}
      <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
      <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    {% endif %}
    <meta property="og:site_name" content="{{ site.name if site and site.name else 'Easy Tech Partners' }}" />
    <meta property="og:title" content="{{ metaTitle | escape }}" />
    <meta property="og:description" content="{{ metaDescription | escape }}" />
    <meta property="og:type" content="{% if pageType == 'article' %}article{% else %}website{% endif %}" />
    {% if pageType == 'article' and date %}
      <meta property="article:published_time" content="{{ date.toISOString() }}" />
    {% endif %}
    {% if image %}
      {% set ogImageUrl = (site.url + image) if site and site.url else image %}
      <meta property="og:image" content="{{ ogImageUrl | escape }}" />
      <meta name="twitter:image" content="{{ ogImageUrl | escape }}" />
      {% if imageAlt %}
        <meta property="og:image:alt" content="{{ imageAlt | escape }}" />
        <meta name="twitter:image:alt" content="{{ imageAlt | escape }}" />
      {% endif %}
      {% if imageWidth %}
        <meta property="og:image:width" content="{{ imageWidth }}" />
      {% endif %}
      {% if imageHeight %}
        <meta property="og:image:height" content="{{ imageHeight }}" />
      {% endif %}
    {% endif %}
    <meta name="twitter:card" content="{% if image %}summary_large_image{% else %}summary{% endif %}" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,300..700,0..1,-50..200"
    />
    {% if isHome %}
      <link rel="preload" as="image" href="/images/hero.jpg" type="image/jpeg" fetchpriority="high" />
    {% endif %}
    <style>
      :root {
        color-scheme: light;
        --bg: #f8fafc;
        --surface: #ffffff;
        --surface-soft: #f1f5f9;
        --border: #e2e8f0;
        --text: #0f172a;
        --muted: #475569;
        --muted-soft: #64748b;
        --primary: #008f4c;
        --primary-dark: #007a41;
        --ring: rgba(0, 143, 76, 0.32);
        --shadow: 0 18px 40px rgba(2, 6, 23, 0.08);
        --radius: 16px;
        --radius-sm: 12px;
        --radius-full: 999px;
        --container: 1120px;
        --header-height: 76px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: var(--primary);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .material-symbols-rounded {
        font-variation-settings:
          "FILL" var(--ms-fill, 0),
          "wght" var(--ms-wght, 500),
          "GRAD" var(--ms-grad, 0),
          "opsz" var(--ms-opsz, 24);
        font-size: 1.05em;
        line-height: 1;
        vertical-align: -0.18em;
        user-select: none;
      }

      .btn .material-symbols-rounded,
      .mobile-nav-cta .material-symbols-rounded {
        margin-right: 2px;
      }

      .skip-link {
        position: absolute;
        left: 16px;
        top: 10px;
        padding: 10px 14px;
        border-radius: var(--radius-full);
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        box-shadow: var(--shadow);
        transform: translateY(-160%);
        transition: transform 180ms ease;
        z-index: 100;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      .container {
        width: 100%;
        max-width: var(--container);
        margin: 0 auto;
        padding: 0 20px;
      }

      .site {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(248, 250, 252, 0.84);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }

      .site-header--overlay {
        background: rgba(248, 250, 252, 0.92);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        min-height: var(--header-height);
        position: relative;
      }

      .brand {
        display: flex;
        align-items: center;
        color: inherit;
      }

      .brand:hover {
        text-decoration: none;
      }

      .brand-logo {
        height: 32px;
        display: flex;
        align-items: center;
      }

      .brand-logo img {
        height: 100%;
        width: auto;
        max-width: 220px;
        display: block;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 9px 12px;
        border-radius: var(--radius-full);
        font-size: 13px;
        font-weight: 650;
        color: var(--muted);
        text-decoration: none;
      }

      .nav-link:hover {
        color: var(--text);
        background: rgba(226, 232, 240, 0.65);
        text-decoration: none;
      }

      .nav-link.is-active {
        background: rgba(0, 143, 76, 0.12);
        color: var(--primary-dark);
      }

      .header-actions {
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: var(--radius-full);
        border: 1px solid transparent;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: -0.01em;
        white-space: nowrap;
        text-decoration: none;
      }

      .btn:hover {
        text-decoration: none;
      }

      .btn:focus-visible {
        outline: 3px solid var(--ring);
        outline-offset: 2px;
      }

      .btn-primary {
        background: linear-gradient(180deg, var(--primary), var(--primary-dark));
        color: #ffffff;
        box-shadow: 0 14px 30px rgba(0, 143, 76, 0.22);
      }

      .btn-primary:hover {
        filter: brightness(1.03);
      }

      .btn-ghost {
        border-color: var(--border);
        background: rgba(255, 255, 255, 0.7);
        color: var(--text);
      }

      .btn-ghost:hover {
        background: var(--surface);
      }

      .mobile-nav {
        display: none;
      }

      .mobile-nav summary {
        list-style: none;
      }

      .mobile-nav summary::-webkit-details-marker {
        display: none;
      }

      .mobile-nav-trigger {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: var(--radius-full);
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.75);
        color: var(--text);
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
      }

      .mobile-nav-icon {
        display: inline-flex;
        width: 18px;
        height: 18px;
        color: currentColor;
      }

      .mobile-nav-icon svg {
        width: 18px;
        height: 18px;
        display: block;
      }

      .mobile-nav-panel {
        position: absolute;
        right: 0;
        top: calc(var(--header-height) - 10px);
        width: min(360px, calc(100vw - 40px));
        padding: 10px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      .mobile-nav-panel a {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 12px 12px;
        border-radius: var(--radius-sm);
        color: var(--text);
        font-weight: 650;
        font-size: 13px;
      }

      .mobile-nav-panel a:hover {
        background: rgba(226, 232, 240, 0.55);
        text-decoration: none;
      }

      .mobile-nav-panel .mobile-nav-cta {
        margin-top: 8px;
        background: rgba(0, 143, 76, 0.1);
        color: var(--primary-dark);
      }

      main {
        flex: 1;
      }

      .section {
        padding: 56px 0;
      }

      .section.compact {
        padding: 34px 0;
      }

      .hero {
        padding: 52px 0 22px;
        background: radial-gradient(circle at top left, rgba(0, 143, 76, 0.14), transparent 45%),
          radial-gradient(circle at top right, rgba(0, 143, 76, 0.1), transparent 55%);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 26px;
        align-items: start;
      }

      .hero-content {
        max-width: 76ch;
      }

      .hero-eyebrow {
        margin: 0 0 10px;
        font-size: 13px;
        font-weight: 750;
        letter-spacing: -0.01em;
        color: var(--primary-dark);
      }

      .hero h1 {
        margin: 0 0 12px;
        font-size: clamp(34px, 4vw, 48px);
        line-height: 1.05;
        letter-spacing: -0.045em;
      }

      .hero h1 span {
        color: var(--primary-dark);
      }

      .hero-lead {
        margin: 0 0 18px;
        max-width: 64ch;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.7;
      }

      .hero-cta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        margin-top: 14px;
      }

      .hero-note {
        margin-top: 10px;
        color: var(--muted-soft);
        font-size: 12px;
      }

      .section-header {
        display: grid;
        gap: 8px;
        margin-bottom: 16px;
      }

      .section-title {
        margin: 0;
        font-size: 20px;
        letter-spacing: -0.02em;
      }

      .section-lead {
        margin: 0;
        color: var(--muted);
        max-width: 72ch;
        font-size: 14px;
        line-height: 1.7;
      }

      .services-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        margin-top: 18px;
      }

      .service-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 16px;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 8px 24px rgba(2, 6, 23, 0.06);
        transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
        color: inherit;
      }

      .service-card:hover {
        text-decoration: none;
        transform: translateY(-2px);
        border-color: rgba(0, 143, 76, 0.28);
        box-shadow: 0 14px 36px rgba(2, 6, 23, 0.09);
      }

      .service-title {
        margin: 0;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .service-desc {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.65;
      }

      .service-meta {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary-dark);
        font-weight: 750;
        font-size: 13px;
      }

      .service-meta span {
        font-size: 16px;
      }

      .page-header {
        padding: 0;
        margin: 0;
      }

      .page-header h1 {
        margin: 0 0 10px;
        font-size: clamp(28px, 2.6vw, 44px);
        line-height: 1.06;
        letter-spacing: -0.05em;
      }

      .page-lead {
        margin: 0;
        color: rgba(15, 23, 42, 0.76);
        max-width: 72ch;
        font-size: 15px;
        line-height: 1.8;
      }

      .page-hero {
        position: relative;
        padding: 34px 0 22px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 250, 252, 0.9) 100%);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        overflow: hidden;
      }

      .page-hero::before {
        content: "";
        position: absolute;
        inset: -40% -20% auto -20%;
        height: 380px;
        background:
          radial-gradient(circle at 18% 28%, rgba(0, 143, 76, 0.16), transparent 60%),
          radial-gradient(circle at 62% 52%, rgba(2, 6, 23, 0.08), transparent 58%),
          radial-gradient(circle at 84% 18%, rgba(0, 143, 76, 0.10), transparent 52%);
        pointer-events: none;
      }

      .page-hero-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .page-breadcrumbs {
        position: relative;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
        margin: 0 0 14px;
        color: rgba(71, 85, 105, 0.85);
        font-size: 12px;
        font-weight: 700;
      }

      .page-breadcrumbs a {
        color: rgba(71, 85, 105, 0.95);
      }

      .page-breadcrumbs .crumb-sep {
        color: rgba(148, 163, 184, 0.9);
      }

      

      .prose {
        max-width: 76ch;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.8;
      }

      .prose h2,
      .prose h3 {
        color: var(--text);
        letter-spacing: -0.015em;
      }

      .prose h2 {
        margin: 26px 0 10px;
        font-size: 18px;
      }

      .prose h3 {
        margin: 18px 0 8px;
        font-size: 16px;
      }

      .prose p {
        margin: 0 0 14px;
      }

      .prose figure {
        margin: 18px 0 18px;
      }

      .prose img {
        max-width: 100%;
        height: auto;
        display: block;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        box-shadow: 0 18px 40px rgba(2, 6, 23, 0.08);
        background: rgba(255, 255, 255, 0.9);
      }

      .prose figcaption {
        margin-top: 10px;
        color: var(--muted-soft);
        font-size: 12px;
        line-height: 1.6;
      }

      .about-split {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 18px;
        align-items: start;
        margin: 0 0 18px;
      }

      .about-photo {
        margin: 0;
      }

      .about-intro p {
        margin: 0 0 14px;
      }

      .prose ul {
        margin: 0 0 16px;
        padding-left: 18px;
      }

      .prose li {
        margin-bottom: 6px;
      }

      .prose pre {
        margin: 16px 0;
        padding: 14px 14px;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(248, 250, 252, 0.9);
        overflow: auto;
        box-shadow: 0 10px 26px rgba(2, 6, 23, 0.06);
        font-size: 13px;
        line-height: 1.55;
        color: var(--text);
      }

      .prose code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 0.95em;
      }

      .site-footer {
        border-top: 1px solid rgba(226, 232, 240, 0.9);
        padding: 26px 0 44px;
        color: var(--muted-soft);
        font-size: 12px;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
        gap: 18px;
        align-items: start;
      }

      .footer-title {
        font-weight: 800;
        color: var(--text);
        margin-bottom: 6px;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 14px;
        justify-content: flex-end;
      }

      .footer-links a {
        color: var(--muted);
        font-weight: 650;
      }

      .footer-links a:hover {
        color: var(--text);
        text-decoration: underline;
      }

      .home-hero {
        margin-top: calc(var(--header-height) * -1);
        padding: calc(84px + var(--header-height)) 0 45px;
        min-height: min(600px, 100vh);
        display: flex;
        align-items: flex-end;
        position: relative;
        background: rgba(2, 6, 23, 1);
        overflow: hidden;
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
      }

      .home-hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
      }

      .home-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          180deg,
          rgba(2, 6, 23, 0.62) 0%,
          rgba(2, 6, 23, 0.28) 45%,
          rgba(2, 6, 23, 0.68) 100%
        );
        z-index: 1;
        pointer-events: none;
      }

      .home-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 30% 20%, rgba(0, 143, 76, 0.22), transparent 55%),
          radial-gradient(circle at 70% 55%, rgba(0, 143, 76, 0.12), transparent 60%);
        z-index: 2;
        pointer-events: none;
      }

      .home-hero .container {
        position: relative;
        z-index: 3;
      }

      .home-hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 16px;
        align-items: center;
      }

      .home-hero h1 {
        margin: 0 0 12px;
        font-size: clamp(34px, 4vw, 52px);
        line-height: 1.03;
        letter-spacing: -0.05em;
        color: #ffffff;
      }

      .home-hero h1 span {
        color: rgba(255, 255, 255, 0.92);
      }

      .home-lead {
        margin: 0 0 18px;
        max-width: 72ch;
        color: rgba(255, 255, 255, 0.86);
        font-size: 16px;
        line-height: 1.75;
      }

      .home-cta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        margin-top: 16px;
      }

      .home-note {
        margin-top: 10px;
        color: rgba(255, 255, 255, 0.72);
        font-size: 12px;
      }

      .home-hero .btn-ghost {
        border-color: rgba(255, 255, 255, 0.28);
        background: rgba(2, 6, 23, 0.18);
        color: rgba(255, 255, 255, 0.92);
      }

      .home-hero .btn-ghost:hover {
        background: rgba(2, 6, 23, 0.28);
      }

      .ai-loop {
        position: relative;
        --ai-loop-accent-rgb: 6, 182, 212;
        --ai-loop-accent: rgb(var(--ai-loop-accent-rgb));
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(248, 250, 252, 0.92) 100%);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        overflow: hidden;
      }

      .ai-loop.section.compact {
        padding: 26px 0 0;
      }

      .ai-loop::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 18% 40%, rgba(6, 182, 212, 0.10), transparent 60%),
          radial-gradient(circle at 62% 52%, rgba(2, 6, 23, 0.06), transparent 58%),
          radial-gradient(circle at 86% 30%, rgba(6, 182, 212, 0.07), transparent 55%);
        pointer-events: none;
      }

      .ai-loop-grid {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 14px;
        align-items: center;
      }

      .ai-loop-copy {
        max-width: 70ch;
      }

      .ai-loop-wrap .section-header {
        gap: 6px;
        margin-bottom: 10px;
      }

      .ai-loop-lead {
        margin: 0 0 14px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
        max-width: 72ch;
      }

      .ai-loop-steps {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 8px;
      }

      .ai-loop-step {
        width: 100%;
        text-align: left;
        display: grid;
        grid-template-columns: 22px minmax(0, 1fr);
        gap: 10px;
        align-items: start;
        padding: 12px 12px;
        border-radius: 14px;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.86);
        box-shadow: 0 10px 26px rgba(2, 6, 23, 0.05);
        cursor: pointer;
        transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease, background 140ms ease;
        color: inherit;
      }

      .ai-loop-step:hover {
        transform: translateY(-1px);
        border-color: rgba(6, 182, 212, 0.22);
        box-shadow: 0 14px 34px rgba(2, 6, 23, 0.07);
        background: rgba(255, 255, 255, 0.92);
      }

      .ai-loop-step:focus-visible {
        outline: 3px solid var(--ring);
        outline-offset: 2px;
      }

      .ai-loop-step-dot {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        margin-top: 3px;
        background: rgba(148, 163, 184, 0.9);
        border: 2px solid rgba(255, 255, 255, 0.95);
        box-shadow: 0 10px 20px rgba(2, 6, 23, 0.12);
      }

      .ai-loop-step-title {
        margin: 0 0 2px;
        font-size: 13px;
        font-weight: 900;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .ai-loop-step-desc {
        margin: 0;
        font-size: 12px;
        line-height: 1.6;
        color: var(--muted);
      }

      .ai-loop-step.is-active {
        border-color: rgba(6, 182, 212, 0.32);
        background: rgba(6, 182, 212, 0.06);
      }

      .ai-loop-step.is-active .ai-loop-step-dot {
        background: rgba(6, 182, 212, 0.92);
      }

      .ai-loop-visual {
        display: none;
        justify-content: center;
        padding: 12px;
        overflow: visible;
      }

      .ai-loop-orbit {
        position: relative;
        width: min(360px, 100%);
        aspect-ratio: 1 / 1;
        border-radius: 999px;
        margin: 0 auto;
        overflow: visible;
      }

      .ai-loop-orbit svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      .ai-loop-center {
        position: absolute;
        inset: 50% auto auto 50%;
        transform: translate(-50%, -50%);
        width: min(240px, 72%);
        text-align: center;
        pointer-events: none;
      }

      .ai-loop-center-label {
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(71, 85, 105, 0.8);
        margin-bottom: 6px;
      }

      .ai-loop-center-step {
        font-size: 15px;
        font-weight: 900;
        letter-spacing: -0.015em;
        color: rgba(15, 23, 42, 0.96);
        line-height: 1.25;
      }

      .ai-loop-track {
        stroke: rgba(148, 163, 184, 0.35);
        stroke-width: 8;
        fill: none;
        filter: drop-shadow(0 10px 16px rgba(2, 6, 23, 0.08));
      }

      .ai-loop-progress {
        stroke: rgba(6, 182, 212, 0.92);
        stroke-width: 8;
        fill: none;
        stroke-linecap: round;
        transform: rotate(-90deg);
        transform-origin: 50% 50%;
        filter:
          drop-shadow(0 0 6px rgba(6, 182, 212, 0.26))
          drop-shadow(0 0 16px rgba(6, 182, 212, 0.14))
          drop-shadow(0 14px 18px rgba(6, 182, 212, 0.08));
        animation: aiLoopLineGlow 2.4s ease-in-out infinite;
      }

      @keyframes aiLoopLineGlow {
        0% {
          filter:
            drop-shadow(0 0 5px rgba(6, 182, 212, 0.18))
            drop-shadow(0 0 12px rgba(6, 182, 212, 0.10))
            drop-shadow(0 14px 16px rgba(6, 182, 212, 0.06));
        }
        50% {
          filter:
            drop-shadow(0 0 8px rgba(6, 182, 212, 0.30))
            drop-shadow(0 0 18px rgba(6, 182, 212, 0.16))
            drop-shadow(0 14px 22px rgba(6, 182, 212, 0.10));
        }
        100% {
          filter:
            drop-shadow(0 0 5px rgba(6, 182, 212, 0.18))
            drop-shadow(0 0 12px rgba(6, 182, 212, 0.10))
            drop-shadow(0 14px 16px rgba(6, 182, 212, 0.06));
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .ai-loop-progress { animation: none; }
      }

      .info-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 18px;
      }

      .info-card {
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 10px 28px rgba(2, 6, 23, 0.07);
        padding: 16px;
      }

      .info-title {
        margin: 0 0 6px;
        font-size: 14px;
        font-weight: 850;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .info-body {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.7;
      }

      .pilot {
        border-radius: var(--radius);
        border: 1px solid rgba(0, 143, 76, 0.28);
        background: rgba(0, 143, 76, 0.06);
        padding: 18px;
        box-shadow: 0 14px 34px rgba(0, 143, 76, 0.12);
      }

      .pilot-meta {
        margin: 0 0 10px;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--primary-dark);
      }

      .pilot-title {
        margin: 0 0 10px;
        font-size: 18px;
        letter-spacing: -0.02em;
      }

      .pilot-body {
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
        max-width: 84ch;
      }

      .pilot-list {
        margin: 0 0 14px;
        padding-left: 18px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.75;
      }

      .partner {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 18px;
        align-items: center;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 10px 28px rgba(2, 6, 23, 0.07);
        padding: 18px;
      }

      .partner-badge {
        display: flex;
        justify-content: flex-start;
      }

      .partner-badge img {
        width: 200px;
        height: auto;
        display: block;
        background: transparent;
        border: none;
        border-radius: 0;
        filter: drop-shadow(0 14px 24px rgba(2, 6, 23, 0.18));
      }

      .partner-kicker {
        margin: 0 0 8px;
        font-size: 12px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--primary-dark);
      }

      .partner-title {
        margin: 0 0 10px;
        font-size: 18px;
        letter-spacing: -0.02em;
        color: var(--text);
      }

      .partner-body {
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
        max-width: 70ch;
      }

      .blog-header {
        display: grid;
        gap: 8px;
        margin-bottom: 18px;
      }

      .blog-title {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.03em;
      }

      .blog-lead {
        margin: 0;
        color: var(--muted);
        max-width: 78ch;
        font-size: 14px;
        line-height: 1.75;
      }

      .blog-search {
        display: grid;
        gap: 8px;
        padding: 12px;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 24px rgba(2, 6, 23, 0.04);
      }

      .blog-search-label {
        font-size: 12px;
        font-weight: 800;
        color: var(--muted);
        letter-spacing: -0.01em;
      }

      .blog-search-input {
        width: 100%;
        padding: 12px 12px;
        border-radius: 12px;
        border: 1px solid var(--border);
        font: inherit;
      }

      .blog-search-input:focus-visible {
        outline: 3px solid var(--ring);
        outline-offset: 2px;
      }

      .blog-search-meta {
        font-size: 12px;
        color: var(--muted-soft);
      }

      .blog-list {
        list-style: none;
        padding: 0;
        margin: 16px 0 0;
        display: grid;
        gap: 12px;
      }

      .blog-grid {
        margin-top: 16px;
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .blog-more {
        margin-top: 14px;
      }

      .post-card {
        display: grid;
        gap: 8px;
        padding: 16px;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 8px 24px rgba(2, 6, 23, 0.06);
      }

      .post-card--compact {
        padding: 14px;
      }

      .post-card-thumb {
        width: 100%;
        height: 140px;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(241, 245, 249, 0.9);
      }

      .post-card-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .post-card-content {
        min-width: 0;
        display: grid;
        gap: 8px;
      }

      .post-card-meta {
        margin: 0;
        color: var(--muted-soft);
        font-size: 12px;
      }

      .post-card-title {
        margin: 0;
        font-size: 16px;
        letter-spacing: -0.02em;
      }

      .post-card-title a {
        color: inherit;
        text-decoration: none;
      }

      .post-card-title a:hover {
        text-decoration: underline;
      }

      .post-card-desc {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.7;
        max-width: 78ch;
      }

      .post-card-more {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 800;
        color: var(--primary-dark);
        text-decoration: none;
      }

      .post-card-more:hover {
        text-decoration: underline;
      }

      .blog-empty {
        margin-top: 14px;
        color: var(--muted);
        font-size: 13px;
      }

      .post-header {
        display: grid;
        gap: 10px;
        margin-bottom: 18px;
        max-width: 80ch;
      }

      .post-meta {
        margin: 0;
        color: var(--muted-soft);
        font-size: 12px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .post-meta-link {
        color: inherit;
        text-decoration: none;
        font-weight: 750;
      }

      .post-meta-link:hover {
        text-decoration: underline;
      }

      .post-title {
        margin: 0;
        font-size: clamp(28px, 3.6vw, 40px);
        line-height: 1.1;
        letter-spacing: -0.045em;
      }

      .post-lead {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
      }

      .post-figure {
        margin: 16px 0 0;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid rgba(226, 232, 240, 0.95);
        box-shadow: 0 10px 30px rgba(2, 6, 23, 0.06);
        background: rgba(255, 255, 255, 0.9);
      }

      .post-figure img {
        width: 100%;
        height: auto;
        display: block;
      }

      @media (min-width: 860px) {
        .about-split {
          grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
          align-items: center;
        }

        .about-photo img {
          aspect-ratio: 4 / 3;
          object-fit: cover;
        }
      }

      @media (max-width: 980px) {
        .services-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .footer-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .footer-links {
          justify-content: flex-start;
        }

        .info-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .partner {
          grid-template-columns: minmax(0, 1fr);
        }

        .home-hero {
          padding-top: calc(77px + var(--header-height));
        }

        .blog-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 860px) {
        .nav,
        .header-actions {
          display: none;
        }

        .mobile-nav {
          display: block;
        }
      }

      @media (max-width: 560px) {
        .container {
          padding: 0 14px;
        }

        .services-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .stats {
          grid-template-columns: minmax(0, 1fr);
        }

        .info-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .blog-grid {
          grid-template-columns: minmax(0, 1fr);
        }
      }

      @media (min-width: 920px) {
        .ai-loop-grid {
          grid-template-columns: minmax(0, 1fr) minmax(0, 440px);
          align-items: center;
        }

        .ai-loop-visual {
          display: flex;
          align-self: center;
        }
      }
    </style>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NGX225S4"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site">
      <header class="site-header{% if isHome %} site-header--overlay{% endif %}" aria-label="Primary navigation">
        <div class="container header-inner">
          <a href="/" class="brand" aria-label="Easy Tech Partners">
            <span class="brand-logo">
              <img src="/images/easy-tech-logo.svg" alt="" />
            </span>
          </a>

          <nav class="nav" aria-label="Site">
            <a href="/services/" class="nav-link{% if isServices %} is-active{% endif %}">Services</a>
            <a href="/about-us/" class="nav-link{% if page.url == '/about-us/' %} is-active{% endif %}">About</a>
            <a href="/blog/" class="nav-link{% if page.url and page.url.indexOf('/blog/') == 0 %} is-active{% endif %}">Blog</a>
          </nav>

          <div class="header-actions">
            <a href="/contact-us/" class="btn btn-ghost">Contact</a>
            <a href="mailto:krystian@easytechpartners.com?subject=Intro%20call%20-%20Autonomous%20AI%20agents" class="btn btn-primary">{% ms "calendar_month" %}<span>Book a meeting</span></a>
          </div>

          <details class="mobile-nav">
            <summary class="mobile-nav-trigger">
              <span class="mobile-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 7H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  <path d="M4 12H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  <path d="M4 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
              <span>Menu</span>
            </summary>
            <div class="mobile-nav-panel" role="dialog" aria-label="Mobile navigation">
              <a href="/services/">Services {% ms "arrow_forward" %}</a>
              <a href="/about-us/">About {% ms "arrow_forward" %}</a>
              <a href="/blog/">Blog {% ms "arrow_forward" %}</a>
              <a href="/contact-us/">Contact</a>
              <a class="mobile-nav-cta" href="mailto:krystian@easytechpartners.com?subject=Intro%20call%20-%20Autonomous%20AI%20agents">{% ms "calendar_month" %}<span>Book a meeting</span></a>
            </div>
          </details>
        </div>
      </header>

      <main id="main">
        {% if isHome %}
          <section class="home-hero">
            <img
              class="home-hero-bg"
              src="/images/hero.jpg"
              alt=""
              aria-hidden="true"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              width="2160"
              height="2700"
            />
            <div class="container">
              <div class="home-hero-grid">
                <div>
                  <h1>
                    AI automation that
                    <span>gets work done</span>
                  </h1>
                  <p class="home-lead">
                    We help you figure out where AI can help, prove it in one workflow, and turn it into a production system.
                    Clear scope, trained team, safe automation, measurable results — built around your tools and data.
                  </p>
                  <div class="home-cta">
                    <a class="btn btn-primary" href="mailto:krystian@easytechpartners.com?subject=Intro%20call%20-%20Autonomous%20AI%20agents">{% ms "calendar_month" %}<span>Book a meeting</span></a>
                    <a class="btn btn-ghost" href="#pilot">{% ms "rocket_launch" %}<span>Apply for the pilot</span></a>
                  </div>
                  <div class="home-note">Straight to the point. Measurable. Production‑minded.</div>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact ai-loop" id="ai-loop" aria-labelledby="ai-loop-title">
            <div class="container">
              <div class="ai-loop-wrap">
                <div class="section-header">
                  <h2 class="section-title" id="ai-loop-title">How automation runs</h2>
                  <p class="section-lead">A simple loop: data → plan → execution → results → better next inputs.</p>
                </div>

                <div class="ai-loop-grid">
                  <div class="ai-loop-copy">
                    <ol class="ai-loop-steps">
                      <li>
                        <button class="ai-loop-step is-active" type="button" data-step="0" aria-current="step">
                          <span class="ai-loop-step-dot" aria-hidden="true"></span>
                          <span>
                            <span class="ai-loop-step-title">Analyze Data</span>
                            <span class="ai-loop-step-desc">Look at your data, context, and constraints.</span>
                          </span>
                        </button>
                      </li>
                      <li>
                        <button class="ai-loop-step" type="button" data-step="1">
                          <span class="ai-loop-step-dot" aria-hidden="true"></span>
                          <span>
                            <span class="ai-loop-step-title">Plan the work</span>
                            <span class="ai-loop-step-desc">Decide the next actions and the checks to run.</span>
                          </span>
                        </button>
                      </li>
                      <li>
                        <button class="ai-loop-step" type="button" data-step="2">
                          <span class="ai-loop-step-dot" aria-hidden="true"></span>
                          <span>
                            <span class="ai-loop-step-title">Execute</span>
                            <span class="ai-loop-step-desc">Run the tasks across your tools with guardrails.</span>
                          </span>
                        </button>
                      </li>
                      <li>
                        <button class="ai-loop-step" type="button" data-step="3">
                          <span class="ai-loop-step-dot" aria-hidden="true"></span>
                          <span>
                            <span class="ai-loop-step-title">Evaluate results</span>
                            <span class="ai-loop-step-desc">Verify quality and measure the impact.</span>
                          </span>
                        </button>
                      </li>
                      <li>
                        <button class="ai-loop-step" type="button" data-step="4">
                          <span class="ai-loop-step-dot" aria-hidden="true"></span>
                          <span>
                            <span class="ai-loop-step-title">Report + improve</span>
                            <span class="ai-loop-step-desc">Send a report and upgrade the next run.</span>
                          </span>
                        </button>
                      </li>
                    </ol>
                  </div>

                  <div class="ai-loop-visual" aria-hidden="true">
                    <div class="ai-loop-orbit">
                      <svg viewBox="0 0 200 200" role="img" aria-label="Animated agent loop">
                        <circle class="ai-loop-track" cx="100" cy="100" r="74"></circle>
                        <circle class="ai-loop-progress" cx="100" cy="100" r="74"></circle>
                      </svg>
                      <div class="ai-loop-center" aria-hidden="true">
                        <div class="ai-loop-center-label">Now</div>
                        <div class="ai-loop-center-step" id="ai-loop-current-step">Analyze Data</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact">
            <div class="container">
              <div class="partner">
                <div>
                  <p class="partner-kicker">AI rollout</p>
                  <h2 class="partner-title">If you don’t know where to start, we’ll make it clear.</h2>
                  <p class="partner-body">
                    We review your workflows, data, and constraints, then propose practical automations that fit your business.
                    We train your team, ship the first workflows, and stay involved as your technical partner as you scale AI across the company.
                  </p>
                  <p class="partner-body">
                    The fastest way to begin is a focused pilot: one workflow end‑to‑end, measurable outcomes, and a repeatable pattern for what’s next.
                  </p>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact">
            <div class="container">
              <div class="section-header">
                <h2 class="section-title">What we build</h2>
                <p class="section-lead">Systems that connect to your tools, do the work, and report results — with safety checks.</p>
              </div>
              <div class="info-grid">
                <div class="info-card">
                  <h3 class="info-title">Workflow automation</h3>
                  <p class="info-body">A reliable workflow that knows what to do next and how to recover when something fails.</p>
                </div>
                <div class="info-card">
                  <h3 class="info-title">AI agents (the workers)</h3>
                  <p class="info-body">Purpose‑built agents that execute specific tasks across your systems — with clear boundaries.</p>
                </div>
                <div class="info-card">
                  <h3 class="info-title">Data + safety checks</h3>
                  <p class="info-body">Checks, logging, and reporting so you can trust what runs — and improve it over time.</p>
                </div>
              </div>
            </div>
          </section>

          <section id="pilot" class="section compact">
            <div class="container">
              <div class="pilot">
                <p class="pilot-meta">Pilot program</p>
                <h2 class="pilot-title">Start with one workflow</h2>
                <p class="pilot-body">
                  We onboard up to three companies at a time to keep delivery hands‑on. The pilot delivers one high‑value workflow end‑to‑end — with clear success metrics, safety checks, and weekly iterations.
                </p>
                <ul class="pilot-list">
                  <li>You have one workflow worth automating first.</li>
                  <li>You can provide access to the right tools and data.</li>
                  <li>You can assign an owner on your side.</li>
                  <li>You want a clear, measurable outcome in weeks.</li>
                </ul>
                <div class="home-cta">
                  <a class="btn btn-primary" href="mailto:krystian@easytechpartners.com?subject=Pilot%20application%20-%20Autonomous%20AI%20agents&body=Hi%20Krystian%2C%0A%0AWe%20want%20to%20apply%20for%20the%20pilot.%0A%0ACompany%3A%0AWebsite%3A%0APrimary%20goal%20(1%20sentence)%3A%0AWorkflow%20to%20automate%3A%0AKey%20systems%20and%20data%20sources%3A%0AConstraints%20(security%2Fcompliance)%3A%0ATeam%20size%3A%0ATimeline%3A%0A%0AThanks%2C">{% ms "rocket_launch" %}<span>Apply for the pilot</span></a>
                </div>
              </div>
            </div>
          </section>

          <section class="section">
            <div class="container">
              <div class="section-header">
                <h2 class="section-title">If you run on HubSpot</h2>
                <p class="section-lead">
                  We can also handle HubSpot delivery: integrations, CMS work, and the technical edge cases that show up after launch.
                </p>
              </div>
              <div class="info-grid">
                <div class="info-card">
                  <h3 class="info-title">HubSpot integrations</h3>
                  <p class="info-body">Reliable API work and data sync between HubSpot and your systems.</p>
                </div>
                <div class="info-card">
                  <h3 class="info-title">HubSpot agency support</h3>
                  <p class="info-body">Technical delivery help for agency teams when needed.</p>
                </div>
                <div class="info-card">
                  <h3 class="info-title">HubSpot CMS websites</h3>
                  <p class="info-body">Custom HubSpot CMS websites: templates, modules, performance, and clean implementation.</p>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact" aria-label="HubSpot partner">
            <div class="container">
              <div class="partner">
                <div class="partner-badge">
                  <img src="/images/partner-badge.webp" alt="HubSpot Solutions Partner badge." loading="lazy" />
                </div>
                <div>
                  <p class="partner-kicker">Trusted partner</p>
                  <h2 class="partner-title">HubSpot Solutions Partner</h2>
                  <p class="partner-body">
                    We deliver HubSpot work in production: CMS websites, integrations, automation, and the edge cases that show up after launch.
                    If you need a reliable delivery partner, book a quick meeting.
                  </p>
                  <div class="home-cta">
                    <a class="btn btn-primary" href="mailto:krystian@easytechpartners.com?subject=Meeting%20-%20HubSpot%20delivery">{% ms "calendar_month" %}<span>Book a meeting</span></a>
                    <a class="btn btn-ghost" href="/contact-us/">Contact</a>
                  </div>
                </div>
              </div>
            </div>
          </section>

	          {% if collections.posts and collections.posts.length %}
	            <section class="section compact" aria-label="Latest blog posts">
	              <div class="container">
	                <div class="section-header">
	                  <h2 class="section-title">Latest from the blog</h2>
	                  <p class="section-lead">Ideas and notes on autonomous agents, growth systems, and shipping production AI.</p>
	                </div>
	                <div class="blog-grid">
	                  {% for post in collections.posts %}
	                    {% if loop.index0 < 3 %}
	                      <article class="post-card post-card--compact">
	                        {% if post.data.image %}
	                          <div class="post-card-thumb" aria-hidden="true">
	                            <img src="{{ post.data.image }}" alt="" loading="lazy" decoding="async" />
	                          </div>
	                        {% endif %}
	                        <div class="post-card-content">
	                          <p class="post-card-meta">
	                            {% if post.date %}
	                              <time datetime="{{ post.date.toISOString() }}">{{ post.date | readableDate(site.locale) }}</time>
	                            {% endif %}
	                          </p>
	                          <h3 class="post-card-title"><a href="{{ post.url }}">{{ post.data.title | escape }}</a></h3>
	                          {% if post.data.description %}
	                            <p class="post-card-desc">{{ post.data.description | escape }}</p>
	                          {% endif %}
	                          <a class="post-card-more" href="{{ post.url }}">Read more {% ms "arrow_forward" %}</a>
	                        </div>
	                      </article>
	                    {% endif %}
	                  {% endfor %}
	                </div>
	                <div class="hero-cta blog-more">
	                  <a class="btn btn-ghost" href="/blog/">See all posts {% ms "arrow_forward" %}</a>
	                </div>
	              </div>
	            </section>
	          {% endif %}
        {% else %}
          {% if renderPageHeader is defined and renderPageHeader == false %}
            {{ content | safe }}
          {% else %}
            <section class="page-hero">
              <div class="container">
                <nav class="page-breadcrumbs" aria-label="Breadcrumb">
                  <a href="/">Home</a>
                  <span class="crumb-sep" aria-hidden="true">/</span>
                  {% if isServices and not isServicesIndex %}
                    <a href="/services/">Services</a>
                    <span class="crumb-sep" aria-hidden="true">/</span>
                  {% elif isBlog and not isBlogIndex %}
                    <a href="/blog/">Blog</a>
                    <span class="crumb-sep" aria-hidden="true">/</span>
                  {% endif %}
                  <span aria-current="page">{{ metaTitle | escape }}</span>
                </nav>

                <div class="page-hero-inner">
                  <div class="page-header">
                    <h1>{{ metaTitle | escape }}</h1>
                    {% if description %}
                      <p class="page-lead">{{ description | escape }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            </section>

            {% if isServicesIndex %}
              <section class="section compact">
                <div class="container">
                  <div class="section-header">
                    <h2 class="section-title">Services</h2>
                    <p class="section-lead">
                      Our main focus is autonomous AI agents. We also support HubSpot integrations and HubSpot agency teams.
                    </p>
                  </div>
                  <div class="services-grid">
                    <a class="service-card" href="/services/ai-agents/">
                      <h3 class="service-title">Autonomous AI agents</h3>
                      <p class="service-desc">Agent systems that plan, execute, and improve growth work in a loop.</p>
                    <div class="service-meta">Explore {% ms "arrow_forward" %}</div>
                  </a>
                  <a class="service-card" href="/services/integrations/">
                    <h3 class="service-title">HubSpot integrations</h3>
                    <p class="service-desc">APIs, reliable sync, and integrations across your stack.</p>
                    <div class="service-meta">Explore {% ms "arrow_forward" %}</div>
                  </a>
                  <a class="service-card" href="/services/hubspot/">
                    <h3 class="service-title">HubSpot support</h3>
                    <p class="service-desc">Technical delivery support for HubSpot agencies (available when needed).</p>
                    <div class="service-meta">Explore {% ms "arrow_forward" %}</div>
                  </a>
                  <a class="service-card" href="/contact-us/">
                    <h3 class="service-title">Pilot application</h3>
                    <p class="service-desc">Applying for the pilot is the fastest way to get started.</p>
                    <div class="service-meta">Contact us {% ms "arrow_forward" %}</div>
                  </a>
                  </div>
                </div>
              </section>
            {% endif %}

            <section class="section">
              <div class="container">
                <article class="prose">
                  {{ content | safe }}
                </article>
              </div>
            </section>
          {% endif %}
        {% endif %}
      </main>

      <footer class="site-footer">
        <div class="container footer-grid">
          <div>
            <div>© 2025, Easy Tech Partners.</div>
          </div>
          <div class="footer-links" aria-label="Footer links">
            <a href="/services/">Services</a>
            <a href="/about-us/">About</a>
            <a href="/blog/">Blog</a>
            <a href="/contact-us/">Contact</a>
            <a href="/privacy-policy/">Privacy policy</a>
            <a href="/cookie-policy/">Cookies</a>
          </div>
        </div>
      </footer>
    </div>
  {% if isHome %}
    <script src="/js/ai-loop.js" defer></script>
  {% endif %}
  </body>
</html>
