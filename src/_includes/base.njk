      .ai-loop {
        position: relative;
        --ai-loop-accent-rgb: var(--accent-tech-rgb);
        --ai-loop-accent: rgb(var(--ai-loop-accent-rgb));
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(248, 250, 252, 0.92) 100%);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        overflow: hidden;
      }

      .ai-loop.section.compact {
        padding: var(--space-section-compact) 0;
      }

      .ai-loop::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 18% 40%, rgba(var(--ai-loop-accent-rgb), 0.10), transparent 60%),
          radial-gradient(circle at 62% 52%, rgba(2, 6, 23, 0.06), transparent 58%),
          radial-gradient(circle at 86% 30%, rgba(var(--ai-loop-accent-rgb), 0.07), transparent 55%);
        pointer-events: none;
      }

      .ai-loop-grid {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 14px;
        align-items: center;
      }

      .ai-loop-copy {
        max-width: 70ch;
      }

      .ai-loop-wrap .section-header {
        gap: var(--space-2xs);
        margin-bottom: var(--space-xs);
      }

      #ai-loop {
        scroll-margin-top: calc(var(--header-height) + 6px);
      }

      .ai-loop-lead {
        margin: 0 0 var(--space-xs);
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
        max-width: 72ch;
      }

      .ai-loop-steps {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 8px;
      }

      .ai-loop-step {
        width: 100%;
        text-align: left;
        display: grid;
        grid-template-columns: 22px minmax(0, 1fr);
        gap: 10px;
        align-items: start;
        padding: 12px 12px;
        border-radius: 14px;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.86);
        box-shadow: 0 10px 26px rgba(2, 6, 23, 0.05);
        cursor: pointer;
        transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease, background 140ms ease;
        color: inherit;
      }

      .ai-loop-step:hover {
        transform: translateY(-1px);
        border-color: rgba(var(--ai-loop-accent-rgb), 0.22);
        box-shadow: 0 14px 34px rgba(2, 6, 23, 0.07);
        background: rgba(255, 255, 255, 0.92);
      }

      .ai-loop-step:focus-visible {
        outline: 3px solid var(--ring);
        outline-offset: 2px;
      }

      .ai-loop-step-dot {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        margin-top: 3px;
        background: rgba(148, 163, 184, 0.9);
        border: 2px solid rgba(255, 255, 255, 0.95);
        box-shadow: 0 10px 20px rgba(2, 6, 23, 0.12);
      }

      .ai-loop-step-title {
        margin: 0 0 2px;
        font-size: 13px;
        font-weight: 900;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .ai-loop-step-desc {
        margin: 0;
        font-size: 12px;
        line-height: 1.6;
        color: var(--muted);
      }

      .ai-loop-step.is-active {
        border-color: rgba(var(--ai-loop-accent-rgb), 0.32);
        background: rgba(var(--ai-loop-accent-rgb), 0.06);
      }

      .ai-loop-step.is-active .ai-loop-step-dot {
        background: rgba(var(--ai-loop-accent-rgb), 0.92);
      }

      .ai-loop-visual {
        display: none;
        justify-content: center;
        padding: 12px;
        overflow: visible;
      }

      .ai-loop-orbit {
        position: relative;
        width: min(360px, 100%);
        aspect-ratio: 1 / 1;
        border-radius: 999px;
        margin: 0 auto;
        overflow: visible;
      }

      .ai-loop-orbit svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      .ai-loop-center {
        position: absolute;
        inset: 50% auto auto 50%;
        transform: translate(-50%, -50%);
        width: min(240px, 72%);
        text-align: center;
        pointer-events: none;
      }

      .ai-loop-center-label {
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(71, 85, 105, 0.8);
        margin-bottom: 6px;
      }

      .ai-loop-center-step {
        font-size: 15px;
        font-weight: 900;
        letter-spacing: -0.015em;
        color: rgba(15, 23, 42, 0.96);
        line-height: 1.25;
      }

      .ai-loop-center.is-animating .ai-loop-center-label,
      .ai-loop-center.is-animating .ai-loop-center-step {
        animation: aiLoopCenterPop 260ms ease-out;
      }

      @keyframes aiLoopCenterPop {
        from {
          transform: translateY(6px);
          opacity: 0.55;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      .ai-loop-track {
        stroke: rgba(148, 163, 184, 0.35);
        stroke-width: 8;
        fill: none;
        filter: drop-shadow(0 10px 16px rgba(2, 6, 23, 0.08));
      }

      .ai-loop-progress {
        stroke: rgba(var(--ai-loop-accent-rgb), 0.92);
        stroke-width: 8;
        fill: none;
        stroke-linecap: round;
        transform: rotate(-90deg);
        transform-origin: 50% 50%;
        transition: stroke-dashoffset 420ms ease;
        filter:
          drop-shadow(0 0 6px rgba(var(--ai-loop-accent-rgb), 0.26))
          drop-shadow(0 0 16px rgba(var(--ai-loop-accent-rgb), 0.14))
          drop-shadow(0 14px 18px rgba(var(--ai-loop-accent-rgb), 0.08));
        animation: aiLoopLineGlow 2.4s ease-in-out infinite;
      }

      .ai-loop-progress.is-resetting {
        transition: none;
      }

      @keyframes aiLoopLineGlow {
        0% {
          filter:
            drop-shadow(0 0 5px rgba(var(--ai-loop-accent-rgb), 0.18))
            drop-shadow(0 0 12px rgba(var(--ai-loop-accent-rgb), 0.10))
            drop-shadow(0 14px 16px rgba(var(--ai-loop-accent-rgb), 0.06));
        }
        50% {
          filter:
            drop-shadow(0 0 8px rgba(var(--ai-loop-accent-rgb), 0.30))
            drop-shadow(0 0 18px rgba(var(--ai-loop-accent-rgb), 0.16))
            drop-shadow(0 14px 22px rgba(var(--ai-loop-accent-rgb), 0.10));
        }
        100% {
          filter:
            drop-shadow(0 0 5px rgba(var(--ai-loop-accent-rgb), 0.18))
            drop-shadow(0 0 12px rgba(var(--ai-loop-accent-rgb), 0.10))
            drop-shadow(0 14px 16px rgba(var(--ai-loop-accent-rgb), 0.06));
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .ai-loop-progress { animation: none; }
        .ai-loop-center.is-animating .ai-loop-center-label,
        .ai-loop-center.is-animating .ai-loop-center-step { animation: none; }
      }

      .info-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-top: 18px;
      }

      .info-card {
        border-radius: 8px;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: none;
        padding: 20px;
      }

      .info-title {
        margin: 0 0 6px;
        font-size: 14px;
        font-weight: 850;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .info-body {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
      }

      .home-why {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.98) 100%);
      }

      .home-why::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 12% 24%, rgba(217, 255, 0, 0.12), transparent 28%),
          radial-gradient(circle at 88% 78%, rgba(238, 242, 255, 0.95), transparent 26%);
        pointer-events: none;
      }

      .home-why .section-header {
        position: relative;
        margin-bottom: 18px;
      }

      .value-stack {
        display: grid;
        gap: 18px;
        margin-top: 24px;
      }

      .value-panel {
        min-height: clamp(420px, 44vw, 520px);
        display: grid;
        grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
        gap: clamp(28px, 5vw, 72px);
        align-items: center;
        padding: 44px;
        border-radius: 12px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        background: rgba(255, 255, 255, 0.9);
        overflow: hidden;
      }

      .value-panel::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 6px;
        background: #e2e8f0;
      }

      .value-panel:nth-child(1)::before {
        background: #c7d2fe;
      }

      .value-panel:nth-child(2)::before {
        background: #d9ff00;
      }

      .value-panel:nth-child(3)::before {
        background: #fda4af;
      }

      .value-panel:nth-child(even) .value-panel-copy {
        order: 2;
      }

      .value-panel:nth-child(even) .value-panel-visual {
        order: 1;
      }

      .value-panel-copy {
        position: relative;
        max-width: 36ch;
      }

      .value-kicker {
        margin: 0 0 8px;
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent-tech-dark);
      }

      .value-title {
        margin: 0 0 14px;
        font-size: clamp(32px, 3.6vw, 48px);
        line-height: 1;
        letter-spacing: -0.03em;
        color: var(--text);
      }

      .value-body {
        margin: 0;
        max-width: 32ch;
        font-size: 18px;
        line-height: 1.42;
        color: var(--muted);
      }

      .value-panel-visual .visual-placeholder {
        min-height: clamp(300px, 34vw, 420px);
        border: 1px solid rgba(15, 23, 42, 0.12);
        border-radius: 12px;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.46)),
          rgba(255, 255, 255, 0.62);
        box-shadow: 0 10px 30px rgba(2, 6, 23, 0.08);
        color: rgba(15, 23, 42, 0.52);
      }

      .pilot {
        border-radius: 8px;
        border: 1px solid rgba(var(--primary-rgb), 0.28);
        background: rgba(var(--primary-rgb), 0.06);
        padding: 28px;
        box-shadow: none;
      }

      .pilot-meta {
        margin: 0 0 var(--space-2xs);
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent-tech-dark);
      }

      .pilot-title {
        margin: 0 0 var(--space-2xs);
        font-size: 20px;
        letter-spacing: -0.02em;
      }

      .pilot-body {
        margin: 0 0 var(--space-xs);
        color: var(--muted);
        font-size: 14px;
        line-height: 1.55;
        max-width: 54ch;
      }

      .pilot-list {
        margin: 0 0 var(--space-xs);
        padding-left: 18px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.55;
      }

      .partner {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: var(--space-sm);
        align-items: center;
        border-radius: 8px;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: none;
        padding: 28px;
      }

      .partner-badge {
        display: flex;
        justify-content: flex-start;
      }

      .partner-badge img {
        width: 200px;
        height: auto;
        display: block;
        background: transparent;
        border: none;
        border-radius: 0;
        filter: drop-shadow(0 14px 24px rgba(2, 6, 23, 0.18));
      }

      .partner-kicker {
        margin: 0 0 var(--space-2xs);
        font-size: 12px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent-tech-dark);
      }

      .partner-title {
        margin: 0 0 var(--space-2xs);
        font-size: 20px;
        letter-spacing: -0.02em;
        color: var(--text);
      }

      .partner-body {
        margin: 0 0 var(--space-xs);
        color: var(--muted);
        font-size: 14px;
        line-height: 1.55;
        max-width: 52ch;
      }

      .blog-header {
        display: grid;
        gap: var(--space-2xs);
        margin-bottom: var(--space-sm);
      }

      .blog-title {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.03em;
      }

      .blog-lead {
        margin: 0;
        color: var(--muted);
        max-width: 78ch;
        font-size: 14px;
        line-height: 1.75;
      }

      .blog-search {
        display: grid;
        gap: 8px;
        padding: 12px;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 24px rgba(2, 6, 23, 0.04);
      }

      .blog-search-label {
        font-size: 12px;
        font-weight: 800;
        color: var(--muted);
        letter-spacing: -0.01em;
      }

      .blog-search-input {
        width: 100%;
        padding: 12px 12px;
        border-radius: 12px;
        border: 1px solid var(--border);
        font: inherit;
      }

      .blog-search-input:focus-visible {
        outline: 3px solid var(--ring);
        outline-offset: 2px;
      }

      .blog-search-meta {
        font-size: 12px;
        color: var(--muted-soft);
      }

      .blog-list {
        list-style: none;
        padding: 0;
        margin: var(--space-sm) 0 0;
        display: grid;
        gap: 12px;
      }

      .blog-grid {
        margin-top: var(--space-sm);
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        align-items: stretch;
      }

      .blog-item {
        height: 100%;
      }

      .blog-more {
        margin-top: var(--space-xs);
      }

      .post-card {
        display: flex;
        flex-direction: column;
        gap: 8px;
        height: 100%;
        padding: 16px;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 8px 24px rgba(2, 6, 23, 0.06);
      }

      .post-card--compact {
        padding: 14px;
      }

      .post-card-thumb {
        width: 100%;
        height: 140px;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(241, 245, 249, 0.9);
      }

      .post-card-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .post-card-content {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1 1 auto;
      }

      .post-card-meta {
        margin: 0;
        color: var(--muted-soft);
        font-size: 12px;
        min-height: 1lh;
      }

      .post-card-title {
        margin: 0;
        font-size: 16px;
        letter-spacing: -0.02em;
      }

      .post-card-title a {
        color: inherit;
        text-decoration: none;
      }

      .post-card-title a:hover {
        text-decoration: underline;
      }

      .post-card-desc {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.7;
        max-width: 78ch;
      }

      .post-card-more {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: auto;
        font-size: 13px;
        font-weight: 800;
        color: var(--accent-tech-dark);
        text-decoration: none;
      }

      .post-card-more:hover {
        text-decoration: underline;
      }

      .blog-empty {
        margin-top: var(--space-xs);
        color: var(--muted);
        font-size: 13px;
      }

      .post-header {
        display: grid;
        gap: 10px;
        margin-bottom: var(--space-sm);
        max-width: 80ch;
      }

      .post-meta {
        margin: 0;
        color: var(--muted-soft);
        font-size: 12px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .post-meta-link {
        color: inherit;
        text-decoration: none;
        font-weight: 750;
      }

      .post-meta-link:hover {
        text-decoration: underline;
      }

      .post-title {
        margin: 0;
        font-size: clamp(28px, 3.6vw, 40px);
        line-height: 1.1;
        letter-spacing: -0.045em;
      }

      .post-lead {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
      }

      .post-figure {
        margin: var(--space-sm) 0 0;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid rgba(226, 232, 240, 0.95);
        box-shadow: 0 10px 30px rgba(2, 6, 23, 0.06);
        background: rgba(255, 255, 255, 0.9);
      }

      .post-figure img {
        width: 100%;
        height: auto;
        display: block;
      }

      @media (min-width: 860px) {
        .about-split {
          grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
          align-items: center;
        }

        .is-contact .prose .contact-layout {
          grid-template-columns: minmax(0, 1fr) minmax(0, 1.08fr);
          align-items: start;
        }

        .is-why-us .prose .whyus-intro {
          grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.95fr);
        }

        .is-why-us .prose .whyus-pillars {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .prose .usecase-table {
          table-layout: fixed;
        }

        .prose .usecase-kpi-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .about-photo img {
          aspect-ratio: 4 / 3;
          object-fit: cover;
        }
      }

      @media (max-width: 980px) {
        .is-lead-plan .leadplan-hero-image {
          display: none;
        }

        .is-lead-plan .leadplan-hero {
          grid-template-columns: 1fr;
          gap: var(--space-sm);
        }

        .is-lead-plan .leadplan-flow {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .services-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .mega-menu {
          width: calc(100vw - 24px);
        }

        .mega-menu-groups {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .mega-menu-quickstart {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .footer-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .footer-links {
          justify-content: flex-start;
        }

        .info-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .value-panel {
          grid-template-columns: minmax(0, 1fr);
        }

        .value-panel:nth-child(even) .value-panel-copy,
        .value-panel:nth-child(even) .value-panel-visual {
          order: initial;
        }

        .partner {
          grid-template-columns: minmax(0, 1fr);
        }

        .home-hero {
          padding-top: calc(var(--space-lg) + var(--header-height));
        }

        .blog-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 760px) {
        .is-lead-plan .leadplan-flow {
          grid-template-columns: 1fr;
        }

        .is-services-index .services-grid-showcase {
          grid-template-columns: minmax(0, 1fr);
        }
      }

      @media (max-width: 860px) {
        .nav,
        .header-actions {
          display: none;
        }

        .mobile-nav {
          display: block;
        }
      }

      @media (max-width: 560px) {
        .container {
          padding: 0 14px;
        }

        .home-cta .btn {
          width: 100%;
          justify-content: center;
        }

        .is-services-index .services-intro,
        .is-services-index .service-cluster,
        .is-services-index .services-cta {
          padding: var(--space-sm);
        }

        .mega-menu-groups {
          grid-template-columns: minmax(0, 1fr);
        }

        .mega-menu-quickstart,
        .prose .trust-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .services-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .table-scroll {
          overflow-x: auto;
        }

        .prose .usecase-kpi-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .conversion-compare {
          grid-template-columns: minmax(0, 1fr);
        }

        .is-why-us .prose .whyus-intro,
        .is-why-us .prose .whyus-pillars {
          grid-template-columns: minmax(0, 1fr);
        }

        .stats {
          grid-template-columns: minmax(0, 1fr);
        }

        .info-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .value-panel {
          gap: 24px;
          padding: 28px;
        }

        .blog-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .prose .visual-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .hero-scroll {
          bottom: -16px;
        }

        .hero-scroll-text {
          display: none;
        }
      }

      @media (min-width: 920px) {
        .home-hero-grid {
          grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
          gap: var(--space-xl);
          align-items: center;
        }

        .feature-panel {
          grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
          align-items: center;
          gap: 44px;
        }

        .feature-panel:nth-child(even) .feature-panel-copy {
          order: 2;
        }

        .feature-panel:nth-child(even) .visual-placeholder {
          order: 1;
        }

        .ai-loop-grid {
          grid-template-columns: minmax(0, 1fr) minmax(0, 440px);
          align-items: center;
        }

        .ai-loop-visual {
          display: flex;
          align-self: center;
        }
      }

    </style>
  </head>
  <body class="{% if isServices %}is-services{% endif %}{% if isServicesIndex %}{% if isServices %} {% endif %}is-services-index{% endif %}{% if isBlog %}{% if isServices or isServicesIndex %} {% endif %}is-blog{% endif %}{% if isContact %}{% if isServices or isServicesIndex or isBlog %} {% endif %}is-contact{% endif %}{% if isWhyUs %}{% if isServices or isServicesIndex or isBlog or isContact %} {% endif %}is-why-us{% endif %}{% if isLeadPlan %}{% if isServices or isServicesIndex or isBlog or isContact or isWhyUs %} {% endif %}is-lead-plan{% endif %}{% if isContent %}{% if isServices or isServicesIndex or isBlog or isContact or isWhyUs or isLeadPlan %} {% endif %}is-content{% endif %}">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site">
      <header class="site-header{% if isHome %} site-header--overlay{% endif %}" aria-label="Primary navigation">
        <div class="container header-inner">
          <a href="{{ homeUrl }}" class="brand" aria-label="Sisivo">
            <span class="brand-logo">
              <img src="{{ site.logo if site and site.logo else '/images/sisivo-mark.svg' }}" alt="" />
            </span>
          </a>

          <div class="header-actions">
            <a href="https://app.sisivo.com" class="btn btn-primary">
              <span class="btn-icon btn-icon--portal" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <g fill="none" stroke="currentColor" stroke-dasharray="20" stroke-dashoffset="20" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                    <path d="M6 19v-1c0 -2.21 1.79 -4 4 -4h4c2.21 0 4 1.79 4 4v1">
                      <animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="20;0"/>
                    </path>
                    <path d="M12 11c-1.66 0 -3 -1.34 -3 -3c0 -1.66 1.34 -3 3 -3c1.66 0 3 1.34 3 3c0 1.66 -1.34 3 -3 3Z">
                      <animate fill="freeze" attributeName="stroke-dashoffset" begin="0.2s" dur="0.2s" values="20;0"/>
                    </path>
                  </g>
                </svg>
              </span>
              <span>{{ signInLabel }}</span>
            </a>
          </div>

          <details class="mobile-nav">
            <summary class="mobile-nav-trigger">
              <span class="mobile-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 7H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  <path d="M4 12H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  <path d="M4 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
              <span>{{ menuLabel }}</span>
            </summary>
            <div class="mobile-nav-panel" role="dialog" aria-label="Mobile navigation">
              <a class="mobile-nav-cta" href="https://app.sisivo.com">
                <span class="btn-icon btn-icon--portal" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <g fill="none" stroke="currentColor" stroke-dasharray="20" stroke-dashoffset="20" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                      <path d="M6 19v-1c0 -2.21 1.79 -4 4 -4h4c2.21 0 4 1.79 4 4v1">
                        <animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="20;0"/>
                      </path>
                      <path d="M12 11c-1.66 0 -3 -1.34 -3 -3c0 -1.66 1.34 -3 3 -3c1.66 0 3 1.34 3 3c0 1.66 -1.34 3 -3 3Z">
                        <animate fill="freeze" attributeName="stroke-dashoffset" begin="0.2s" dur="0.2s" values="20;0"/>
                      </path>
                    </g>
                  </svg>
                </span>
                <span>{{ signInLabel }}</span>
              </a>
            </div>
          </details>
        </div>
      </header>

      <main id="main">
        {% if isHome %}
          <section class="home-hero">
            <img
              class="home-hero-bg"
              src="/images/hero-image.jpg"
              alt=""
              aria-hidden="true"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              width="1536"
              height="1024"
            />
            <div class="container">
              <div class="home-hero-grid">
                <div>
                  <h1>
                    Sisivo turns pipeline chaos
                    <span>into a sales system</span>
                  </h1>
                  <p class="home-lead">
                    For B2B teams with deals, outbound, and a CRM, but no shared way to qualify, run, and win deals.
                  </p>
                  <div class="home-cta home-cta--hero">
                    <a class="btn btn-primary" href="{{ calendarUrl }}">{% ms "calendar_month" %}<span>Book Pipeline Review</span></a>
                    <a class="cta-inline-link" href="{{ roadmapUrl }}">
                      <span>Learn more</span>
                      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M3.5 8H12.5" stroke-width="1.8" stroke-linecap="round" />
                        <path d="M8.8 4.3L12.5 8L8.8 11.7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </a>
                  </div>
                  <div class="home-note">For B2B SaaS and complex-service teams. First value in 1-2 weeks.</div>
                </div>
                <div class="home-hero-visual">
                  <div class="visual-placeholder visual-placeholder--hero">
                    Product hero screenshot placeholder
                    <br />
                    Pipeline view, deal scoring, or system overview
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact" aria-label="Use cases">
            <div class="container">
              <div class="section-header">
                <h2 class="section-title">Use Sisivo to fix what breaks in sales</h2>
                <p class="section-lead">Three jobs. One system.</p>
              </div>
              <div class="feature-stack">
                <div class="feature-panel">
                  <div class="feature-panel-copy">
                    <p class="feature-eyebrow">01</p>
                    <h3 class="feature-title">Tighten ICP and qualification</h3>
                    <p class="feature-desc">Decide who belongs in the pipeline and who does not.</p>
                  </div>
                  <div class="visual-placeholder visual-placeholder--feature">ICP / qualification screen placeholder</div>
                </div>
                <div class="feature-panel">
                  <div class="feature-panel-copy">
                    <p class="feature-eyebrow">02</p>
                    <h3 class="feature-title">Run a cleaner pipeline</h3>
                    <p class="feature-desc">Make stages real and remove dead deals faster.</p>
                  </div>
                  <div class="visual-placeholder visual-placeholder--feature">Pipeline control screen placeholder</div>
                </div>
                <div class="feature-panel">
                  <div class="feature-panel-copy">
                    <p class="feature-eyebrow">03</p>
                    <h3 class="feature-title">Show the revenue impact</h3>
                    <p class="feature-desc">Show where revenue is lost and what can be recovered.</p>
                  </div>
                  <div class="visual-placeholder visual-placeholder--feature">ROI / uplift view placeholder</div>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact home-why" aria-label="Why Sisivo">
            <div class="container">
              <div class="section-header">
                <h2 class="section-title">Why teams use Sisivo</h2>
                <p class="section-lead">Less noise. Better decisions. More control.</p>
              </div>
              <div class="value-stack">
                <div class="value-panel">
                  <div class="value-panel-copy">
                    <p class="value-kicker">Why 01</p>
                    <h3 class="value-title">Know which deals deserve time</h3>
                    <p class="value-body">Targeting, qualification, and pipeline entry stop being guesswork.</p>
                  </div>
                  <div class="value-panel-visual">
                    <div class="visual-placeholder visual-placeholder--feature">Targeting / qualification illustration placeholder</div>
                  </div>
                </div>
                <div class="value-panel">
                  <div class="value-panel-copy">
                    <p class="value-kicker">Why 02</p>
                    <h3 class="value-title">Give every rep the same system</h3>
                    <p class="value-body">Stages, discovery, and next steps become shared and repeatable.</p>
                  </div>
                  <div class="value-panel-visual">
                    <div class="visual-placeholder visual-placeholder--feature">Rep workflow / stage system placeholder</div>
                  </div>
                </div>
                <div class="value-panel">
                  <div class="value-panel-copy">
                    <p class="value-kicker">Why 03</p>
                    <h3 class="value-title">Show the commercial case faster</h3>
                    <p class="value-body">Founders can see what is stuck, what is lost, and what to fix next.</p>
                  </div>
                  <div class="value-panel-visual">
                    <div class="visual-placeholder visual-placeholder--feature">Revenue impact / decision support placeholder</div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact">
            <div class="container">
              <div class="section-header">
                <h2 class="section-title">What’s inside</h2>
                <p class="section-lead">Three core views.</p>
              </div>
              <div class="feature-stack">
                <div class="feature-panel">
                  <div class="feature-panel-copy">
                    <p class="feature-eyebrow">View 01</p>
                    <h3 class="feature-title">ICP and targeting</h3>
                    <p class="feature-desc">See who fits, who does not, and which signals matter before the pipeline gets noisy.</p>
                  </div>
                  <div class="visual-placeholder visual-placeholder--feature">ICP workspace screenshot placeholder</div>
                </div>
                <div class="feature-panel">
                  <div class="feature-panel-copy">
                    <p class="feature-eyebrow">View 02</p>
                    <h3 class="feature-title">Messaging and discovery</h3>
                    <p class="feature-desc">Give reps one way to frame pain, surface urgency, and run a stronger discovery.</p>
                  </div>
                  <div class="visual-placeholder visual-placeholder--feature">Messaging / discovery screenshot placeholder</div>
                </div>
                <div class="feature-panel">
                  <div class="feature-panel-copy">
                    <p class="feature-eyebrow">View 03</p>
                    <h3 class="feature-title">Pipeline and deal control</h3>
                    <p class="feature-desc">Track real stage movement, next steps, and ownership across the whole pipeline.</p>
                  </div>
                  <div class="visual-placeholder visual-placeholder--feature">Pipeline / deal control screenshot placeholder</div>
                </div>
              </div>
            </div>
          </section>

          <section class="section compact" aria-label="Sisivo next step call to action">
            <div class="container">
              <div class="partner lead-plan-panel">
                <div>
                  <p class="partner-kicker">Next step</p>
                  <h2 class="partner-title">See the system on your pipeline</h2>
                  <p class="partner-body">Start with a recent CRM export. Sisivo shows where deals are lost, what should change, and whether the rollout makes sense now.</p>
                  <div class="home-cta">
                    <a class="btn btn-primary" href="{{ calendarUrl }}">{% ms "calendar_month" %}<span>Book Pipeline Review</span></a>
                  </div>
                </div>
              </div>
            </div>
          </section>

          {% if faqSchema and faqSchema.length %}
            <section class="section compact" aria-label="FAQ">
              <div class="container">
                <div class="section-header">
                  <h2 class="section-title">{% if isPolish %}FAQ{% else %}FAQ{% endif %}</h2>
                  <p class="section-lead">{% if isPolish %}Najczęstsze pytania o dopasowanie, dane z CRM, koszt i sposób wdrożenia Sisivo.{% else %}Common questions about fit, CRM data, cost, and how Sisivo gets implemented.{% endif %}</p>
                </div>
                <div class="prose">
                  {% for item in faqSchema %}
                    <h3>{{ item.question }}</h3>
                    <p>{{ item.answer }}</p>
                  {% endfor %}
                </div>
              </div>
            </section>
          {% endif %}

        {% else %}
          {% if renderPageHeader is defined and renderPageHeader == false %}
            {{ content | safe }}
          {% else %}
            <section class="page-hero">
              <div class="container">
                <nav class="page-breadcrumbs" aria-label="Breadcrumb">
                  <a href="{{ homeUrl }}">{{ homeLabel }}</a>
                  <span class="crumb-sep" aria-hidden="true">/</span>
                  {% if isServices and not isServicesIndex %}
                    <a href="/services/">Product</a>
                    <span class="crumb-sep" aria-hidden="true">/</span>
                  {% elif isStart and page.url != '/start-with-ai/' %}
                    <a href="/start-with-ai/">Start with a Pilot</a>
                    <span class="crumb-sep" aria-hidden="true">/</span>
                  {% endif %}
                  <span aria-current="page">{{ pageHeading | escape }}</span>
                </nav>

                <div class="page-hero-inner">
                  <div class="page-header">
                    <h1>{{ pageHeading | escape }}</h1>
                    {% if description %}
                      <p class="page-lead">{{ description | escape }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            </section>

            <section class="section">
              <div class="container">
                <article class="prose">
                  {{ content | safe }}
                </article>
                {% if isServices and not isServicesIndex %}
                  {% set ctaTitle = "Porozmawiajmy o tym, czy Sisivo ma sens dla Twojego pipeline" if isPolish else "Need help deciding whether Sisivo fits your pipeline?" %}
                  {% set ctaBody = "Powiedz nam, jak dziś wygląda sprzedaż, a pomożemy ocenić dopasowanie, zakres pilota i następny krok." if isPolish else "Tell us how your sales process works today and we will help you evaluate fit, pilot scope, and the right next step." %}
                  {% set ctaButton = "Umów przegląd pipeline" if isPolish else "Book Pipeline Review" %}
                  <section class="service-page-cta" aria-label="Service contact call to action">
                    <h2>{{ ctaTitle }}</h2>
                    <p>{{ ctaBody }}</p>
                    <div class="home-cta">
                      <a class="btn btn-primary" href="{{ calendarUrl }}">{% ms "calendar_month" %}<span>{{ ctaButton }}</span></a>
                      <a class="btn btn-ghost btn-see-services" href="{{ roadmapUrl }}"><span class="btn-icon btn-icon--roadmap" aria-hidden="true"></span><span>{% if isPolish %}Dowiedz się więcej{% else %}Learn more{% endif %}</span></a>
                    </div>
                  </section>
                {% endif %}
              </div>
            </section>
          {% endif %}
        {% endif %}
      </main>

      <footer class="site-footer">
        <div class="container footer-grid">
          <div>
            <div>© 2026, Sisivo.</div>
            <div class="footer-build">
              Updated:
              <time datetime="{{ build.iso }}">{{ build.display }}</time>
            </div>
          </div>
          <div class="footer-links" aria-label="Footer links">
            <a href="/privacy-policy/">Privacy policy</a>
            <a href="/cookie-policy/">Cookies</a>
          </div>
        </div>
      </footer>
    </div>
    <button
      class="cookie-fab"
      id="cookie-fab"
      type="button"
      aria-label="Cookie settings"
      hidden
    >
      {% ms "cookie" %}
    </button>
    <div
      class="cookie-banner"
      id="cookie-banner"
      role="dialog"
      aria-label="Cookie preferences"
      aria-live="polite"
      hidden
    >
      <div class="cookie-inner">
          <div>
            <p class="cookie-title">{% if isPolish %}Cookies{% else %}Cookies{% endif %}</p>
            <p class="cookie-text">
              {% if isPolish %}
                Używamy niezbędnych plików cookie, aby strona działała poprawnie. Za Twoją zgodą używamy także cookies analitycznych, aby rozumieć sposób korzystania ze strony i ją ulepszać.
                Swoją decyzję możesz zmienić w każdej chwili w ustawieniach cookies.
              {% else %}
                We use essential cookies to make this site work. With your permission, we also use analytics cookies to understand how the site is used and improve it.
                You can change your choice any time in Cookie settings.
              {% endif %}
            </p>
            <a class="cookie-link" href="{% if isPolish %}/pl/polityka-cookies/{% else %}/cookie-policy/{% endif %}">{% if isPolish %}Przeczytaj politykę cookies{% else %}Read our cookie policy{% endif %}</a>
            <div class="cookie-settings" id="cookie-settings" hidden>
              <div class="cookie-setting">
                <div>
                  <p class="cookie-setting-title">{% if isPolish %}Niezbędne{% else %}Necessary{% endif %}</p>
                  <p class="cookie-setting-desc">{% if isPolish %}Wymagane do działania strony.{% else %}Required for the site to function.{% endif %}</p>
                </div>
                <div class="cookie-switch is-on" aria-hidden="true" title="Necessary cookies are always on">
                  <span class="cookie-switch-thumb" aria-hidden="true"></span>
                </div>
              </div>
              <div class="cookie-setting">
                <div>
                  <p class="cookie-setting-title">{% if isPolish %}Analityczne{% else %}Analytics{% endif %}</p>
                  <p class="cookie-setting-desc">{% if isPolish %}Pomagają nam zrozumieć użycie strony i ją ulepszać (GA4).{% else %}Helps us understand usage and improve the site (GA4).{% endif %}</p>
                </div>
              <label class="cookie-switch" for="cookie-analytics-toggle">
                <input type="checkbox" id="cookie-analytics-toggle" aria-label="{% if isPolish %}Włącz analityczne pliki cookie{% else %}Enable analytics cookies{% endif %}" />
                <span class="cookie-switch-thumb" aria-hidden="true"></span>
              </label>
              </div>
            </div>
          </div>
        <div class="cookie-actions">
          <button class="btn btn-ghost" type="button" data-cookie-reject>{% if isPolish %}Odrzuć{% else %}Reject{% endif %}</button>
          <button class="btn btn-ghost" type="button" data-cookie-customize>{% if isPolish %}Dostosuj{% else %}Customize{% endif %}</button>
          <button class="btn btn-primary" type="button" data-cookie-accept>{% if isPolish %}Akceptuj cookies{% else %}Accept cookies{% endif %}</button>
        </div>
      </div>
    </div>
  {% if isHome %}
    <script src="/js/ai-loop.js" defer></script>
  {% endif %}
  {% if isServices and not isServicesIndex %}
    <script src="/js/faq-accordion.js" defer></script>
    <script src="/js/related-services.js" defer></script>
  {% endif %}
    <script src="/js/cookie-consent.js" defer></script>
  </body>
</html>
