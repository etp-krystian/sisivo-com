          0 10px 24px rgba(2, 6, 23, 0.12),
          0 1px 0 rgba(255, 255, 255, 0.86) inset;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        animation: hero-scroll-bob 1.6s ease-in-out infinite;
