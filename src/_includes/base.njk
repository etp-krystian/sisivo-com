<!doctype html>
{% set pageLocale = 'en' %}
{% set isPolish = pageLocale == 'pl' %}
{% set homeUrl = '/' %}
{% set consultingUrl = '/pl/wdrozenia-ai-dla-firm/' if isPolish else '/services/ai-solutions-development/' %}
{% set roadmapUrl = '/pl/wdrozenia-ai-dla-firm/' if isPolish else '/services/ai-solutions-development/' %}
{% set homeLabel = 'Strona główna' if isPolish else 'Home' %}
{% set calendarLabel = 'Umów przegląd pipeline' if isPolish else 'Book Pipeline Review' %}
{% set signInLabel = 'Go to portal' %}
{% set servicesLabel = 'System sprzedaży' if isPolish else 'Product' %}
{% set howItWorksLabel = 'Jak to działa' if isPolish else 'How It Works' %}
{% set aboutLabel = 'Dlaczego Sisivo' if isPolish else 'Why Sisivo' %}
{% set menuLabel = 'Menu' if isPolish else 'Menu' %}
{% set langSwitchLabel = 'EN' if isPolish else 'PL' %}
{% set langSwitchText = 'English' if isPolish else 'Polski' %}
{% set langSwitchHint = 'Wersja językowa' if isPolish else 'Language' %}
{% set isHome = page.url == "/" %}
{% set isServicesIndex = page.url == "/services/" %}
{% set isServices = page.url and page.url.indexOf("/services/") == 0 %}
{% set isBlog = false %}
{% set isBlogIndex = false %}
{% set isLegal = page.url == "/privacy-policy/" or page.url == "/cookie-policy/" or page.url == "/pl/polityka-prywatnosci/" or page.url == "/pl/polityka-cookies/" %}
{% set isStart = page.url == "/start-with-ai/" or page.url == "/implementation-process/" or page.url == "/business-ai-faq/" %}
{% set isContact = page.url == "/contact-us/" or page.url == "/pl/kontakt/" %}
{% set isWhyUs = page.url == "/why-us/" %}
{% set isLeadPlan = page.url == "/services/ai-solutions-development/" %}
{% set isContent = not isHome %}
{% set calendarUrl = "https://calendar.app.google/R21jua9szDGa7T7c9" %}
{% set alternates = {} %}
{% set canonicalPath = canonicalPath or page.url %}
{% set canonicalUrl = (site.url + canonicalPath) if site and site.url and canonicalPath else canonicalPath %}
{% set organization = site.organization or {} %}
{% set organizationId = (site.url + '#organization') if site and site.url else '#organization' %}
{% set organizationLogo = (site.url + organization.logo) if site and site.url and organization.logo else organization.logo %}
{% set isPrimaryServicePage = page.url == '/' or page.url == '/services/ai-solutions-development/' %}
{% set breadcrumbHomeUrl = homeUrl %}
{% set breadcrumbHomeLabel = homeLabel %}
{% set languageSwitchUrl = '' %}
<html lang="{{ pageLocale }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script>
      document.documentElement.classList.add("js");
    </script>
    {% set metaTitle = title or "Sisivo" %}
    {% set pageHeading = heading or metaTitle %}
    {% set metaDescription = description or "Sisivo helps B2B teams design and run a predictable sales system." %}
    {% set defaultFeaturedImage = "/images/favicon.png" %}
    {% set effectiveImage = image %}
    {% set effectiveImageAlt = imageAlt %}
    {% set effectiveImageWidth = imageWidth %}
    {% set effectiveImageHeight = imageHeight %}
    {% if not effectiveImage and pageType != "article" %}
      {% set effectiveImage = defaultFeaturedImage %}
      {% set effectiveImageAlt = "Sisivo" %}
      {% set effectiveImageWidth = 512 %}
      {% set effectiveImageHeight = 512 %}
    {% endif %}
    <title>{{ metaTitle | escape }}</title>
    <meta name="description" content="{{ metaDescription | escape }}" />
    <meta http-equiv="content-language" content="{{ pageLocale }}" />
    <meta name="language" content="{{ pageLocale }}" />
    {% if canonicalUrl %}
      <link rel="canonical" href="{{ canonicalUrl }}" />
      <meta property="og:url" content="{{ canonicalUrl }}" />
    {% endif %}
    {% if site and site.url and site.url.length %}
      <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ canonicalPath }}" />
    {% endif %}
    <meta property="og:site_name" content="{{ site.name if site and site.name else 'Sisivo' }}" />
    <meta property="og:title" content="{{ metaTitle | escape }}" />
    <meta property="og:description" content="{{ metaDescription | escape }}" />
    <meta property="og:type" content="{% if pageType == 'article' %}article{% else %}website{% endif %}" />
    {% if pageType == 'article' and date %}
      <meta property="article:published_time" content="{{ date.toISOString() }}" />
    {% endif %}
    {% if effectiveImage %}
      {% set ogImageUrl = (site.url + effectiveImage) if site and site.url else effectiveImage %}
      <meta property="og:image" content="{{ ogImageUrl | escape }}" />
      <meta name="twitter:image" content="{{ ogImageUrl | escape }}" />
      {% if effectiveImageAlt %}
        <meta property="og:image:alt" content="{{ effectiveImageAlt | escape }}" />
        <meta name="twitter:image:alt" content="{{ effectiveImageAlt | escape }}" />
      {% endif %}
      {% if effectiveImageWidth %}
        <meta property="og:image:width" content="{{ effectiveImageWidth }}" />
      {% endif %}
      {% if effectiveImageHeight %}
        <meta property="og:image:height" content="{{ effectiveImageHeight }}" />
      {% endif %}
    {% endif %}
    <meta name="twitter:card" content="{% if effectiveImage %}summary_large_image{% else %}summary{% endif %}" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    {% if site and site.url and site.url.length %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": {{ organizationId | json | safe }},
      "name": {{ organization.name | default(site.name) | json | safe }},
      "url": {{ site.url | json | safe }},
      {% if organizationLogo %}"logo": {{ organizationLogo | json | safe }},{% endif %}
      {% if organization.email %}"email": {{ organization.email | json | safe }},{% endif %}
      {% if organization.telephone %}"telephone": {{ organization.telephone | json | safe }},{% endif %}
      {% if organization.sameAs and organization.sameAs.length %}"sameAs": {{ organization.sameAs | json | safe }},{% endif %}
      "address": {
        "@type": "PostalAddress",
        {% if organization.addressLocality %}"addressLocality": {{ organization.addressLocality | json | safe }},{% endif %}
        {% if organization.addressRegion %}"addressRegion": {{ organization.addressRegion | json | safe }},{% endif %}
        {% if organization.addressCountry %}"addressCountry": {{ organization.addressCountry | json | safe }}{% else %}"addressCountry": "PL"{% endif %}
      },
      "areaServed": [
        { "@type": "City", "name": "Warsaw" },
        { "@type": "Country", "name": "Poland" }
      ],
      "contactPoint": [{
        "@type": "ContactPoint",
        {% if organization.telephone %}"telephone": {{ organization.telephone | json | safe }},{% endif %}
        {% if organization.email %}"email": {{ organization.email | json | safe }},{% endif %}
        "contactType": "sales",
        "availableLanguage": ["English"]
      }]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": {{ (site.url + '#website') | json | safe }},
      "url": {{ site.url | json | safe }},
      "name": {{ site.name | json | safe }},
      "description": {{ site.description | json | safe }},
      "publisher": {
        "@id": {{ organizationId | json | safe }}
      },
      "inLanguage": "en"
    }
    </script>
    {% if isPrimaryServicePage %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "@id": {{ (canonicalUrl + '#service') | json | safe }},
      "name": {{ pageHeading | json | safe }},
      "url": {{ canonicalUrl | json | safe }},
      "description": {{ metaDescription | json | safe }},
      "provider": {
        "@id": {{ organizationId | json | safe }}
      },
      "serviceType": {{ pageHeading | json | safe }},
      "areaServed": [
        { "@type": "City", "name": "Warsaw" },
        { "@type": "Country", "name": "Poland" }
      ],
      "availableLanguage": ["English"]
    }
    </script>
    {% endif %}
    {% if isContact %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "@id": {{ (canonicalUrl + '#contact-page') | json | safe }},
      "url": {{ canonicalUrl | json | safe }},
      "name": {{ pageHeading | json | safe }},
      "description": {{ metaDescription | json | safe }},
      "about": {
        "@id": {{ organizationId | json | safe }}
      }
    }
    </script>
    {% endif %}
    {% if faqSchema and faqSchema.length %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for item in faqSchema %}
        {
          "@type": "Question",
          "name": {{ item.question | json | safe }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ item.answer | json | safe }}
          }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
    </script>
    {% endif %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ breadcrumbHomeLabel | json | safe }},
          "item": {{ (site.url + breadcrumbHomeUrl) | json | safe }}
        }
        {% if isServices and not isServicesIndex %}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": "Product",
          "item": {{ (site.url + '/services/') | json | safe }}
        }
        ,{
          "@type": "ListItem",
          "position": 3,
          "name": {{ pageHeading | json | safe }},
          "item": {{ canonicalUrl | json | safe }}
        }
        {% else %}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ pageHeading | json | safe }},
          "item": {{ canonicalUrl | json | safe }}
        }
        {% endif %}
      ]
    }
    </script>
    {% endif %}
    <style>
      :root {
        color-scheme: light;
        --cc-bg: #F8FAFC;
        --cc-surface: #FFFFFF;
        --cc-sidebar-surface: #F1F5F9;
        --cc-section-surface: #F8FAFC;
        --app-stage-bg-rgb: 248, 250, 252;
        --cc-border: #E5E7EB;
        --cc-primary: #111827;
        --cc-primary-hover: #0F172A;
        --cc-success: #D9FF00;
        --cc-warning: #D97706;
        --cc-error: #DC2626;
        --cc-text: #0A0A0A;
        --cc-text-secondary: #64748B;
        --cc-muted: #94A3B8;
        --cc-hover: #F1F5F9;
        --cc-selected: #F8FAFF;
        --cc-progress-bg: #E5E7EB;
        --button-shadow: none;
        --button-shadow-hover: none;
        --brand-green: var(--cc-success);
        --brand-green-soft: var(--cc-success);
        --brand-green-dark: var(--cc-success);
        --brand-green-rgb: 217, 255, 0;

        --bg: var(--cc-bg);
        --surface: var(--cc-surface);
        --surface-soft: var(--cc-sidebar-surface);
        --border: var(--cc-border);
        --text: var(--cc-text);
        --muted: var(--cc-text-secondary);
        --muted-soft: var(--cc-muted);
        --primary: var(--cc-success);
        --primary-soft: var(--brand-green-soft);
        --primary-dark: var(--cc-primary);
        --primary-rgb: var(--brand-green-rgb);
        --accent-tech: var(--cc-primary);
        --accent-tech-dark: var(--cc-primary-hover);
        --accent-tech-rgb: 17, 24, 39;
        --ring: rgba(var(--brand-green-rgb), 0.28);
        --shadow: var(--button-shadow);
        --radius: 16px;
        --radius-sm: 12px;
        --radius-full: 999px;
        --btn-radius: 999px;
        --btn-height: 42px;
        --container: 1120px;
        --header-height: 76px;
        --space-2xs: 8px;
        --space-xs: 12px;
        --space-sm: 16px;
        --space-md: 24px;
        --space-lg: 32px;
        --space-xl: 48px;
        --space-2xl: 64px;
        --space-section: clamp(64px, 7vw, 88px);
        --space-section-compact: clamp(44px, 5.5vw, 64px);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: var(--accent-tech-dark);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .material-symbols-rounded {
        width: 1.05em;
        height: 1.05em;
        vertical-align: -0.16em;
        stroke: currentColor;
        fill: none;
        user-select: none;
        color: currentColor;
      }

      .btn .material-symbols-rounded,
      .mobile-nav-cta .material-symbols-rounded {
        margin-right: 2px;
      }

      .btn--icon-right .material-symbols-rounded {
        margin-right: 0;
        margin-left: 2px;
        vertical-align: 0;
      }

      .btn-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        height: 14px;
        flex: 0 0 14px;
      }

      .btn-icon svg {
        width: 14px;
        height: 14px;
        display: block;
        stroke: currentColor;
      }

      .btn-icon--portal {
        width: 18px;
        height: 18px;
        flex: 0 0 18px;
      }

      .btn-icon--portal svg {
        width: 18px;
        height: 18px;
      }

      .btn-icon--roadmap {
        width: 15px;
        height: 15px;
        flex: 0 0 15px;
        background-color: currentColor;
        -webkit-mask-image: url("/images/icons/material-symbols/ai-roadmap.svg");
        mask-image: url("/images/icons/material-symbols/ai-roadmap.svg");
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
        -webkit-mask-size: contain;
        mask-size: contain;
      }

      .btn .btn-icon--roadmap {
        margin-right: 2px;
      }

      .btn-see-services {
        gap: 7px;
        padding: 10px 14px 10px 16px;
        letter-spacing: -0.005em;
      }

      .skip-link {
        position: absolute;
        left: 16px;
        top: 10px;
        padding: 10px 14px;
        border-radius: var(--radius-full);
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        box-shadow: var(--shadow);
        transform: translateY(-160%);
        transition: transform 180ms ease;
        z-index: 100;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      .cookie-banner {
        position: fixed;
        left: 16px;
        right: 16px;
        bottom: 16px;
        z-index: 200;
        border-radius: var(--radius);
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(10px);
        box-shadow: 0 18px 40px rgba(2, 6, 23, 0.12);
      }

      .cookie-banner[hidden] {
        display: none;
      }

      .cookie-fab {
        position: fixed;
        left: 16px;
        bottom: 16px;
        z-index: 190;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(10px);
        box-shadow: 0 18px 40px rgba(2, 6, 23, 0.12);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text);
      }

      .cookie-fab:hover {
        background: rgba(255, 255, 255, 0.98);
      }

      .cookie-fab:focus-visible {
        outline: 3px solid var(--ring);
        outline-offset: 2px;
      }

      .cookie-fab .material-symbols-rounded {
        font-size: 22px;
        vertical-align: 0;
      }

      .cookie-fab[hidden] {
        display: none;
      }

      .cookie-inner {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 12px;
        padding: 14px 14px;
      }

      .cookie-title {
        margin: 0 0 6px;
        font-size: 13px;
        font-weight: 850;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .cookie-text {
        margin: 0;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.7;
        max-width: 92ch;
      }

      .cookie-settings {
        margin-top: 12px;
        display: grid;
        gap: 10px;
      }

      .cookie-settings[hidden] {
        display: none;
      }

      .cookie-setting {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 14px;
        border: 1px solid rgba(226, 232, 240, 0.95);
        background: rgba(248, 250, 252, 0.72);
      }

      .cookie-setting-title {
        margin: 0;
        color: var(--text);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: -0.01em;
      }

      .cookie-setting-desc {
        margin: 2px 0 0;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.55;
      }

      .cookie-switch {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 26px;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.75);
        background: rgba(226, 232, 240, 0.75);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
        flex: 0 0 auto;
      }

      .cookie-switch input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
      }

      .cookie-switch-thumb {
        width: 20px;
        height: 20px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(148, 163, 184, 0.45);
        transform: translateX(-9px);
        transition: transform 160ms ease, border-color 160ms ease;
        box-shadow: 0 10px 20px rgba(2, 6, 23, 0.14);
      }

      .cookie-switch.is-on .cookie-switch-thumb,
      .cookie-switch input:checked + .cookie-switch-thumb {
        transform: translateX(9px);
        border-color: rgba(15, 23, 42, 0.85);
      }

      .cookie-switch.is-on {
        border-color: rgba(15, 23, 42, 0.85);
        background: rgba(15, 23, 42, 0.92);
      }

      .cookie-switch input:focus-visible + .cookie-switch-thumb {
        outline: 3px solid var(--ring);
        outline-offset: 2px;
      }

      .cookie-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .cookie-link {
        color: var(--muted);
        font-weight: 700;
        font-size: 12px;
      }

      .cookie-link:hover {
        color: var(--text);
      }

      @media (min-width: 860px) {
        .cookie-inner {
          grid-template-columns: minmax(0, 1fr) auto;
          align-items: center;
        }

        .cookie-actions {
          justify-content: flex-end;
        }
      }

      .container {
        width: 100%;
        max-width: var(--container);
        margin: 0 auto;
        padding: 0 clamp(14px, 2vw, 20px);
      }

      .site {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(248, 250, 252, 0.84);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }

      .site-header--overlay {
        background: rgba(248, 250, 252, 0.92);
        border-bottom: 1px solid rgba(226, 232, 240, 0.9);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 16px;
        min-height: var(--header-height);
        position: relative;
      }

      .brand {
        display: flex;
        align-items: center;
        color: inherit;
      }

      .brand:hover {
        text-decoration: none;
      }

      .brand-logo {
        height: 32px;
        display: flex;
        align-items: center;
      }

      .brand-logo img {
        height: 100%;
        width: auto;
        max-width: 220px;
        display: block;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .nav-item {
        position: relative;
        display: inline-flex;
        align-items: center;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 9px 12px;
        border-radius: var(--radius-full);
        font-size: 13px;
        font-weight: 650;
        color: var(--muted);
        text-decoration: none;
      }

      .nav-item--mega .nav-link {
        gap: 6px;
      }

      .nav-chevron {
        display: inline-flex;
        align-self: center;
        width: 12px;
        height: 12px;
        transform: translateY(0.5px) rotate(0deg);
        transform-origin: 50% 50%;
        opacity: 0.62;
        transition:
          transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 200ms ease-in-out;
      }

      .nav-chevron svg {
        width: 100%;
        height: 100%;
        display: block;
        stroke: currentColor;
      }

      .nav-item--mega::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 100%;
        height: 12px;
      }

      .nav-link:hover {
        color: var(--text);
        background: rgba(226, 232, 240, 0.65);
        text-decoration: none;
      }

      .nav-link.is-active {
        background: rgba(var(--accent-tech-rgb), 0.14);
        color: var(--accent-tech-dark);
      }

      .nav-item--mega .nav-link.is-active {
        background: rgba(226, 232, 240, 0.62);
        color: var(--text);
      }

      .nav-item--mega:hover .nav-chevron,
      .nav-item--mega:focus-within .nav-chevron {
        transform: translateY(0.5px) rotate(180deg);
        opacity: 1;
      }

      .mega-menu {
        position: fixed;
        top: calc(var(--header-height) - 1px);
        left: 50%;
        width: calc(100vw - 28px);
        max-width: 1560px;
        padding: var(--space-sm);
        border-radius: var(--radius);
        border: 1px solid rgba(148, 163, 184, 0.26);
        background: rgba(255, 255, 255, 0.98);
        box-shadow:
          0 18px 36px rgba(2, 6, 23, 0.10),
          0 2px 6px rgba(2, 6, 23, 0.04);
        backdrop-filter: blur(6px);
        opacity: 0;
        visibility: hidden;
        transform: translate(-50%, 6px) scale(0.985);
        transition:
          opacity 240ms ease-in-out,
